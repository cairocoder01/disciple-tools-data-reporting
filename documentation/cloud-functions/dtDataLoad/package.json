    "@google-cloud/firestore": "^8.5.0",
    "@google-cloud/storage": "^7.19.0",
    "csv-stringify": "^6.7.0",
    "escape-html": "^1.0.3",
    "moment": "^2.30.1"
  },
  "devDependencies": {
    "@google-cloud/functions-framework": "^5.0.2"
  }
}
