{
  "name": "dtdataload",
  "version": "1.2.2",
  "description": "",
  "main": "index.js",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "start": "npx functions-framework --target=dtDataLoad",
    "deploy:dev": "gcloud functions deploy dtDataLoad --gen2 --runtime nodejs24 --trigger-http --env-vars-file .env.yaml",
    "deploy:create": "gcloud functions deploy dtDataLoad --gen2 --runtime nodejs24 --trigger-http --env-vars-file .env-prod.yaml --region europe-west2 --allow-unauthenticated",
    "test": "npx jest --no-watchman"
  },
